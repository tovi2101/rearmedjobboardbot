# Get from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Your channel ID (starts with -100). See README for how to get it.
CHANNEL_ID=-1001234567890

# Comma-separated Telegram user IDs of admins (get yours from @userinfobot)
ADMIN_IDS=123456789,987654321

# Path to SQLite file. On Railway, mount a volume at /data and keep this as-is.
DB_PATH=/data/jobs.db
